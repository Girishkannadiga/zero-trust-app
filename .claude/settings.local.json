      "PowerShell(Get-Content \"d:\\\\Finalproject\\\\backend\\\\app.log\" -Tail 50 | Where-Object { $_ -match \"Unhandled|NullPointer|Error|Cannot|Failed\" } | Select-Object -Last 20)",
      "Bash(mvn clean *)"
    ]
  }
}
